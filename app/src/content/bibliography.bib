	file = {Preprint PDF:/Users/luis/Zotero/storage/MHNXGP3K/Li et al. - 2024 - Multimodal ArXiv A Dataset for Improving Scientific Comprehension of Large Vision-Language Models.pdf:application/pdf},
}

